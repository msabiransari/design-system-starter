{
  "name": "@acme/fixture-angular7-primeng",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=10.9.0 <13.0.0"
  },
  "scripts": {
    "ng": "ng",
    "prepare:acme": "mkdir -p src/assets/acme/themes src/assets/acme/adapters && cp ../../tokens.css ../../base-scoped.css ../../motion.css ../../primitives.css src/assets/acme/ && cp ../../themes/*.css src/assets/acme/themes/ && cp ../../adapters/primeng7-adapter.css src/assets/acme/adapters/",
    "prestart": "npm run prepare:acme",
    "prebuild": "npm run prepare:acme",
    "start": "ng serve --port 8083",
    "build": "ng build",
    "serve": "python3 -m http.server 8083 --directory dist/angular7-primeng"
  },
  "dependencies": {
    "@angular/animations": "^7.2.0",
    "@angular/common": "^7.2.0",
    "@angular/compiler": "^7.2.0",
    "@angular/core": "^7.2.0",
    "@angular/cdk": "^7.3.7",
    "@angular/forms": "^7.2.0",
    "@angular/platform-browser": "^7.2.0",
    "@angular/platform-browser-dynamic": "^7.2.0",
    "@angular/router": "^7.2.0",
    "core-js": "^2.6.0",
    "primeicons": "^1.0.0",
    "primeng": "^7.1.3",
    "rxjs": "~6.3.3",
    "tslib": "^1.9.0",
    "zone.js": "~0.8.26"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "~0.13.0",
    "@angular/cli": "~7.3.0",
    "@angular/compiler-cli": "^7.2.0",
    "@angular/language-service": "^7.2.0",
    "typescript": "~3.2.2"
  }
}
